# =============================================================================
# terraform.tfvars.example
#
# Copy this to terraform.tfvars and edit.
# Variable names here match the fields in ../config.yaml 1:1.
# =============================================================================

# --- Required ---
project_id = "my-gcp-project"

# --- Region (Vertex) ---
# "global" is the recommended default. Pick a specific region for data
# residency (e.g. "europe-west3"). See ARCHITECTURE.md for the list.
region          = "global"
fallback_region = "us-central1" # used for GCE/Cloud Run when region="global"

# --- Components ---
enable_llm_gateway   = true
enable_mcp_gateway   = true
enable_dev_vm        = false # off by default; costs money when on
enable_dev_portal    = true
enable_observability = true

# --- Dev VM (only used when enable_dev_vm = true) ---
dev_vm_mode                     = "shared"
dev_vm_machine_type             = "e2-small"
dev_vm_disk_size_gb             = 30
dev_vm_auto_shutdown_idle_hours = 2
dev_vm_install_vscode_server    = true

# --- Networking ---
use_psc           = false # enable only for on-prem clients via Interconnect
use_vpc_connector = true  # saves ~$10/mo when false; see COSTS.md

# --- Access control ---
# Google identities granted access to the gateways, dev VM, and portal.
allowed_principals = [
  "user:[email protected]",
  # "group:[email protected]",
]

# --- Model pinning ---
pin_model_versions = true
model_opus         = "claude-opus-4-6"
model_sonnet       = "claude-sonnet-4-6"
model_haiku        = "claude-haiku-4-5@20251001"

# --- Image tags ---
# Populated automatically by scripts/deploy.sh after it builds + pushes.
# Leave blank on a first terraform apply; the modules handle the empty
# case by deploying a placeholder image you can swap out later.
# llm_gateway_image = "us-central1-docker.pkg.dev/my-project/claude-code-vertex-gcp/llm-gateway:latest"
# mcp_gateway_image = "us-central1-docker.pkg.dev/my-project/claude-code-vertex-gcp/mcp-gateway:latest"
# dev_portal_image  = "us-central1-docker.pkg.dev/my-project/claude-code-vertex-gcp/dev-portal:latest"
